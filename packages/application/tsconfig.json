{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": "../..",
    "paths": {
      "@domain": ["packages/domain/src/index.ts"],
      "@domain/*": ["packages/domain/src/*"],
      "@application": ["packages/application/index.ts"],
      "@application/*": ["packages/application/*"]
